# Copia este archivo a .env.local (dev) o .env.production (prod)
# Nunca subas el archivo real con secretos al repo.

# URL del backend Python usada en src/auth.ts
PY_BACKEND_URL=http://localhost:8000

# NextAuth (v5):
# - AUTH_SECRET es el secreto principal recomendado
# - NEXTAUTH_SECRET sigue funcionando en muchos setups por compatibilidad
# Usa uno u otro (idealmente AUTH_SECRET).
AUTH_SECRET=change_me_to_a_long_random_value
#NEXTAUTH_SECRET=change_me_to_a_long_random_value

# URL pública del frontend (necesaria para callbacks OAuth)
NEXTAUTH_URL=http://localhost:3000

# Credenciales OAuth Google
AUTH_GOOGLE_ID=your_google_client_id
AUTH_GOOGLE_SECRET=your_google_client_secret
