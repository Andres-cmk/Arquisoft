POSTGRES_USER=postgres
POSTGRES_PASSWORD=admin
POSTGRES_DB=arqui
DATABASE_URL=postgresql://postgres:admin@db:5432/arqui
FIREBASE_CREDENTIALS=config/serviceAccountKey.json

# Google OAuth (must match the Client ID used in NextAuth)
GOOGLE_CLIENT_ID=

# Allow browser calls from the Next.js frontend (optional)
FRONTEND_ORIGIN=http://localhost:3000

# Used by matchmaking-service/shared security
AUTH_TOKEN_SECRET=replace-this-dev-secret

# Used by shared CORS helper (matchmaking-service)
ALLOWED_ORIGINS=*
